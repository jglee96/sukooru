{
  "name": "@sukooru/svelte",
  "version": "0.1.0",
  "type": "module",
  "description": "Sukooru Svelte 어댑터",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@sukooru/core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0 || ^4.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "svelte": "^5.39.3"
  }
}

{
  "name": "sukooru-next",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Sukooru Next.js 어댑터",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jglee96/sukooru.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/jglee96/sukooru/tree/main/packages/next#readme",
  "bugs": {
    "url": "https://github.com/jglee96/sukooru/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "sukooru-core": "workspace:*",
    "sukooru-react": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}

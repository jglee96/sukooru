{
  "name": "@sukooru/nuxt",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "description": "Nuxt bindings for Sukooru scroll restoration.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jglee96/sukooru.git",
    "directory": "packages/nuxt"
  },
  "homepage": "https://github.com/jglee96/sukooru/tree/main/packages/nuxt#readme",
  "bugs": {
    "url": "https://github.com/jglee96/sukooru/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sukooru/core": "workspace:*",
    "@sukooru/vue": "workspace:*"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0",
    "vue": "^3.3.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "vue": "^3.5.13"
  }
}

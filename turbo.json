{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        ".nuxt/**",
        ".output/**",
        "node_modules/.cache/nuxt/**"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {}
  }
}
